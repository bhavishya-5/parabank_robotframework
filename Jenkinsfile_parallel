pipeline {
    agent any

    parameters {
        choice(name: 'ENV', choices: ['qa', 'dev'], description: 'Target environment (maps to config/env.yaml)')
        string(name: 'PROCESSES', defaultValue: '4', description: 'Number of parallel Pabot processes')
        string(name: 'TAGS', defaultValue: '', description: 'Optional: only run tests with these tags')
        booleanParam(name: 'HEADLESS', defaultValue: true, description: 'Run browser tests headless')
        booleanParam(name: 'TESTLEVEL_SPLIT', defaultValue: false, description: 'Split at test level instead of suite level (more parallelism)')
    }

    options {
        timestamps()
        timeout(time: 45, unit: 'MINUTES')
        buildDiscarder(logRotator(numToKeepStr: '20'))
        disableConcurrentBuilds()
    }

    environment {
        VENV        = '.venv'
        RESULTS_DIR = 'results'
        ALLURE_DIR  = 'results/allure'
        PABOT_DIR   = 'results/pabot'
        ENV_TARGET  = "${params.ENV}"
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Setup Python venv') {
            steps {
                sh '''
                    set -eux
                    python3 -m venv "${VENV}"
                    . "${VENV}/bin/activate"
                    python -m pip install --upgrade pip
                    pip install -r requirements.txt
                    pabot --version || true
                '''
            }
        }

        stage('Lint / Dry Run') {
            steps {
                sh '''
                    set -eux
                    . "${VENV}/bin/activate"
                    robot --dryrun --output NONE --report NONE --log NONE tests/ || true
                '''
            }
        }

        stage('Run Tests in Parallel (Pabot)') {
            steps {
                sh '''
                    set -eux
                    . "${VENV}/bin/activate"
                    mkdir -p "${RESULTS_DIR}" "${ALLURE_DIR}" "${PABOT_DIR}"

                    SPLIT_ARG="--testlevelsplit"
                    if [ "${TESTLEVEL_SPLIT}" != "true" ]; then
                        SPLIT_ARG=""
                    fi

                    TAG_ARGS=""
                    if [ -n "${TAGS}" ]; then
                        TAG_ARGS="--include ${TAGS}"
                    fi

                    pabot \
                        --processes ${PROCESSES} \
                        ${SPLIT_ARG} \
                        --pabotlibport 0 \
                        --pabotprerunmodifier "" \
                        --outputdir "${RESULTS_DIR}" \
                        --listener allure_robotframework:${ALLURE_DIR} \
                        --variable ENV:${ENV_TARGET} \
                        --variable HEADLESS:${HEADLESS} \
                        --xunit xunit.xml \
                        ${TAG_ARGS} \
                        tests/
                '''
            }
        }

        stage('Generate Metrics Report') {
            steps {
                sh '''
                    set -eux
                    . "${VENV}/bin/activate"
                    cd "${RESULTS_DIR}"
                    robotmetrics --inputpath . --output output.xml || true
                '''
            }
        }
    }

    post {
        always {
            junit testResults: "${RESULTS_DIR}/xunit.xml", allowEmptyResults: true

            archiveArtifacts artifacts: "${RESULTS_DIR}/**", allowEmptyArchive: true, fingerprint: true

            // Robot Framework Jenkins plugin (merged Pabot output)
            robot(
                outputPath: "${RESULTS_DIR}",
                outputFileName: 'output.xml',
                reportFileName: 'report.html',
                logFileName: 'log.html',
                passThreshold: 90.0,
                unstableThreshold: 75.0,
                disableArchiveOutput: false,
                otherFiles: '**/*.png'
            )

            // Allure Jenkins plugin
            allure includeProperties: false, jdk: '', results: [[path: "${ALLURE_DIR}"]]
        }
        cleanup {
            cleanWs()
        }
    }
}
